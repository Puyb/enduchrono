#!/usr/bin/env bash

set -u

SERVICES=(chrono classements)
UI_SERVICES=(classements-ui)

echo "Running tests before push..."

failed=0

for service in "${SERVICES[@]}"; do
  echo
  echo "==> ${service}: npm test"

  if ! (docker compose --profile dev up --exit-code-from ${service}-test ${service}-test); then
    echo "ERROR: tests failed in ${service}"
    failed=1
  fi
done

for service in "${UI_SERVICES[@]}"; do
  echo
  echo "==> ${service}: lint + tests unitaires + tests d'integration"

  if ! (docker compose --profile dev up --exit-code-from ${service}-test ${service}-test); then
    echo "ERROR: tests failed in ${service}"
    failed=1
  fi
done

if [ "${failed}" -ne 0 ]; then
  echo
  echo "Push blocked: at least one service test suite failed."
  exit 1
fi

echo
echo "All service tests passed. Push allowed."
exit 0
