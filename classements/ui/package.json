{
  "name": "classement-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "NODE_OPTIONS=--openssl-legacy-provider vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "test:unit": "jest --config jest.config.js --runInBand --testPathPattern=test/unit",
    "test:integration": "jest --config jest.config.js --runInBand --testPathPattern=test/integration",
    "test:e2e:smoke": "playwright test test/e2e/smoke",
    "test:e2e:core": "playwright test test/e2e/core",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "bootstrap-icons": "^1.11.3",
    "bootstrap-vue": "^2.23.1",
    "chart.js": "^3.9.1",
    "core-js": "^3.6.4",
    "vue": "^2.6.11",
    "vue-chartjs": "^4.1.2",
    "vue-router": "^3.6.5",
    "vuex": "^3.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@playwright/test": "^1.61.1",
    "@vue/cli-plugin-babel": "~4.3.1",
    "@vue/cli-plugin-eslint": "~4.3.1",
    "@vue/cli-plugin-vuex": "~4.3.1",
    "@vue/cli-service": "~4.3.1",
    "@vue/test-utils": "^1.3.6",
    "@vue/vue2-jest": "^29.2.6",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^29.7.0",
    "eslint": "^6.8.0",
    "eslint-plugin-vue": "^6.2.2",
    "globals": "^15.11.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "vue-template-compiler": "^2.6.11"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "babel-eslint"
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "allowScripts": {
    "bootstrap-vue@2.23.1": true,
    "core-js@3.30.2": true,
    "ejs@2.7.4": true,
    "yorkie@2.0.0": true
  }
}
